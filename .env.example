# ══════════════════════════════════════════════════════════════════════════════
# Halifax Energy Demand Forecasting — Environment Configuration EXAMPLE
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── SQL Server Configuration ──────────────────────────────────────────────────
SA_PASSWORD=YourStrongPassword123!
MSSQL_DATABASE=HalifaxEnergyProject

# ── Database Connection String ────────────────────────────────────────────────
DATABASE_URL=mssql+pyodbc://sa:YourStrongPassword123!@localhost:1433/HalifaxEnergyProject?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

# ── FastAPI Configuration ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# ── CORS Origins ──────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Scheduler Configuration ───────────────────────────────────────────────────
CCEI_POLL_TIME=06:00
MODEL_RETRAIN_CRON=0 4 * * *

# ── R Model Configuration ─────────────────────────────────────────────────────
R_SCRIPT_PATH=./model/HalifaxEnergy_Model.R
RSCRIPT_BIN=Rscript

# ── External API Keys ─────────────────────────────────────────────────────────
ELEC_MAPS_TOKEN=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/halifaxenergy.log

# ── GeoJSON Data Path ─────────────────────────────────────────────────────────
GEOJSON_ZONES_PATH=./data/geojson/halifax_zones.geojson
